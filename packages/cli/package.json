{
	"name": "@tasktrace/cli",
	"version": "0.0.1",
	"description": "TaskTrace CLI — developer worklog from the terminal",
	"type": "module",
	"main": "./src/index.ts",
	"bin": {
		"tasktrace": "./dist/index.js",
		"tt": "./dist/index.js"
	},
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"dev": "tsc --watch"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/userNanni/TaskTrace.git",
		"directory": "packages/cli"
	},
	"dependencies": {
		"@tasktrace/core": "workspace:*",
		"@tasktrace/adapter-clickup": "workspace:*",
		"citty": "^0.1.6",
		"@clack/prompts": "^0.10.0",
		"picocolors": "^1.1.1"
	}
}
