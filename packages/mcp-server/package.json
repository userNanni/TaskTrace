{
	"name": "@tasktrace/mcp-server",
	"version": "0.0.1",
	"description": "MCP server for TaskTrace — AI agent integration",
	"type": "module",
	"main": "./src/index.ts",
	"bin": {
		"tasktrace-mcp": "./dist/index.js"
	},
	"exports": {
		".": {
			"bun": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": ["dist", "README.md"],
	"scripts": {
		"build": "tsc",
		"typecheck": "tsc --noEmit",
		"test": "bun test",
		"dev": "tsc --watch"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/userNanni/TaskTrace.git",
		"directory": "packages/mcp-server"
	},
	"dependencies": {
		"@tasktrace/core": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.12.1",
		"zod": "^3.24.4"
	}
}
